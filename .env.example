# ===========================================
# Hati Pentest Agent - 环境变量配置模板
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
# ===========================================

# ===========================================
# MiniMax API (必填 — LLM 推理)
# 注册地址: https://www.minimax.chat
# ===========================================
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_group_id_here
MINIMAX_MODEL=MiniMax-M2.7

# ===========================================
# Redis (必填 — 任务进度追踪、消息队列)
# Windows 启动: docker-compose up -d redis
# 也可使用本地 Redis
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_DB_PROGRESS=2

# ===========================================
# Elasticsearch (可选 — 审计日志存储)
# Windows 启动: docker-compose up -d elasticsearch
# 如未安装 ES 包，系统会自动降级为本地文件日志
# ===========================================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# ===========================================
# Docker (可选 — 隔离容器执行, 当前 Windows 下通过 VM MCP 替代)
# ===========================================
DOCKER_HOST=unix:///var/run/docker.sock
TOOLKIT_IMAGE=kalilinux/kali-rolling:latest

# ===========================================
# HexStrike MCP Server (必填 — 渗透测试工具调用)
# 运行在 Kali VM 中，提供 54+ 安全工具 (nmap/nuclei/sqlmap/...)
# 替换为你的 Kali VM IP 地址
# ===========================================
HEXSTRIKE_SERVER_URL=http://your_kali_vm_ip:9999

# ===========================================
# SSH Tunnel 配置 (可选 — 安全访问 VM MCP)
# 在 Windows 上通过 SSH 隧道转发 MCP 端口到本地
# 启动: powershell -File scripts/ssh_tunnel.ps1
# 或:   bash scripts/ssh_tunnel.sh
# ===========================================
SSH_TUNNEL_HOST=your_kali_vm_ip_here
SSH_TUNNEL_PORT=22
SSH_TUNNEL_USER=root
SSH_TUNNEL_PASSWORD=your_vm_password_here
SSH_TUNNEL_LOCAL_PORT=9999
SSH_TUNNEL_REMOTE_PORT=9999

# ===========================================
# RAG 知识库 (必填 — POC 向量数据库)
# 基于 ChromaDB + sentence-transformers
# 首次使用前需构建: python scripts/build_rag.py
# ===========================================
CVE_KB_PATH=./data/cve_knowledge_base
POC_KB_PATH=./data/poc_knowledge_base
POC_REPO_PATH=./poc/wpoc
CHROMA_DB_PATH=./data/poc_knowledge_base
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===========================================
# API 配置
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET_KEY=change-me-in-production-use-random-string

# ===========================================
# 安全配置
# ===========================================
APPROVAL_REQUIRED=true
AUDIT_LOGGING_ENABLED=true
